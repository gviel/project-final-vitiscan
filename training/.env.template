# Copier en training/.env (gitignoré) et compléter. Toutes ces valeurs sont aussi surchargeables
# en ligne de commande (cf. train.py --help).
#
# Valeurs par défaut alignées sur notebooks/CNN_model_FT.ipynb (dataset inrae, notebook de
# référence réellement utilisé pour entraîner le modèle actuellement en prod - cf. docs/refactoring.md).

MLFLOW_URI=https://gviel-mlflow37.hf.space/
# Nom de BASE de l'expérience : train.py ajoute automatiquement le suffixe _FINE_TUNING quand
# --freeze-base=true et --unfreeze-layer est défini (comme le notebook). Expérience réelle utilisée
# jusqu'ici : Vitiscan_CNN_Resnet_INRAE_FINE_TUNING.
EXPERIMENT_NAME=Vitiscan_CNN_Resnet_INRAE

MODEL_NAME=resnet34
EPOCHS=25
PATIENCE=5
BATCH_SIZE=32
LEARNING_RATE=0.0001
WEIGHT_DECAY=0.0001
TRAIN_SPLIT=0.8
FREEZE_BASE=true
UNFREEZE_LAYER=layer4

DATASET_NAME=inrae
# Défaut si non renseigné : ./data-<DATASET_NAME> (ex: ./data-inrae), comme le notebook.
DATA_DIR=
# Défaut si non renseigné : <DATA_DIR>/dataset_inrae.zip. Si absent en local, téléchargé depuis
# s3://TRAINING_S3_BUCKET/data-inrae/dataset_inrae.zip (cf. data_utils.py).
DATASET_ZIP_PATH=
DATASET_URL=https://www.kaggle.com/api/v1/datasets/download/codewithsk/grapes-leafs-disease-7-classes-plantcity-2025

# ── AWS S3 (mêmes credentials pour les deux buckets ci-dessous) ─────────────
# aws-s3-mlflow : bucket MLflow (artifacts modèle), implicite - jamais paramétré par nom ici, géré
# par le SDK MLflow via MLFLOW_URI + ces credentials.
# TRAINING_S3_BUCKET : bucket dédié aux données Vitiscan (dataset + disease.json de secours),
# distinct du bucket MLflow (cf. docs/refactoring.md).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
TRAINING_S3_BUCKET=s3-vitiscan-data
