# Copier en .env (gitignoré) et compléter.
# Secret partagé entre plusieurs composants (docker-compose.yml racine, airflow/docker-compose.yml,
# rag-llm/.env) : la clé API du Weaviate "prod" (celui de la stack applicative principale), lue
# par tous les clients qui doivent s'y connecter (rag-llm local, DAG dag_rag_ingestion::ingest_prod,
# et le tunnel ngrok pour simuler un accès depuis Render).
WEAVIATE_API_KEY=

# Token ngrok (dashboard.ngrok.com/get-started/your-authtoken) - uniquement nécessaire pour
# `docker-compose --profile ngrok up -d ngrok`, cf. docs/simulation-prod-ngrok.md.
NGROK_AUTHTOKEN=
