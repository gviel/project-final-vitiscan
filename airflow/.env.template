# Copier en airflow/.env (gitignoré) et compléter.
# Fichier réel centralisé dans ~/.vitiscan/airflow/.env et symlinké ici - cf. link-env.sh à la
# racine pour (re)créer le lien dans un nouveau worktree.

# ── Documents de connaissance RAG (S3) ───────────────────────────────────────
RAG_S3_BUCKET=s3-vitiscan-data
RAG_S3_PREFIX=knowledge/current/

# ── Neon (Postgres/pgvector) validation/prod, cf. dags/config.py ─────────────
# 2 branches Neon créées manuellement au préalable (branching natif Neon) - remplacent les 2
# anciennes instances Weaviate test/prod. "validation" n'est pas un environnement de déploiement
# séparé : c'est une étape de validation pré-prod (ingestion -> golden prompts -> promotion prod).
DATABASE_URL_VALIDATION=
DATABASE_URL_PROD=

DAG_RAG_INGESTION_CRON=0 * * * *

# ── Golden prompts (porte de qualité avant promotion en prod, cf. dags/tasks/rag_ingestion.py::
# run_golden_prompts_gate) ───────────────────────────────────────────────────
# URL Render du service vitiscan-rag-llm-validation (cf. render.yaml), même code que
# vitiscan-rag-llm mais branché sur DATABASE_URL_VALIDATION. La porte de qualité y rejoue les
# golden prompts en HTTP réel avant de promouvoir vers la prod - teste aussi le service réellement
# déployé, pas seulement les données. Les identifiants HF (HF_API_TOKEN...) sont configurés
# directement sur ce service Render, plus besoin de les dupliquer ici.
RAG_LLM_VALIDATION_URL=

# ── Sweep multi-modèles CNN (dag_train_model) ────────────────────────────────
MLFLOW_URI=https://gviel-mlflow37.hf.space/
EXPERIMENT_NAME=Vitiscan_CNN_Resnet_INRAE
# Bucket données Vitiscan (dataset + disease.json), distinct du bucket MLflow (aws-s3-mlflow,
# implicite, géré par le SDK MLflow - jamais paramétré par nom ici).
TRAINING_S3_BUCKET=s3-vitiscan-data

# ── AWS S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
