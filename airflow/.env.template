# Copier en airflow/.env (gitignoré) et compléter.

# ── Documents de connaissance RAG (S3) ───────────────────────────────────────
RAG_S3_BUCKET=s3-vitiscan-data
RAG_S3_PREFIX=knowledge/current/

# ── Weaviate "prod" (docker-compose.yml racine, projet Compose distinct) ────
# Valeurs par défaut correctes si le docker-compose.yml racine tourne sur cette même machine
# (host.docker.internal + port publié 8081, cf. docker-compose.yml racine).
WEAVIATE_PROD_HOST=host.docker.internal
WEAVIATE_PROD_PORT=8081

DAG_RAG_INGESTION_CRON=0 * * * *

# ── Golden prompts (porte de qualité avant promotion en prod, cf. dags/tasks/rag_ingestion.py::
# run_golden_prompts_gate) ───────────────────────────────────────────────────
# Optionnel : sans HF_API_TOKEN, la porte fonctionne quand même (résolution du nommage + dosage
# vérifiés), seule la vérification des mots-clés du diagnostic LLM est skip. Mêmes valeurs que
# rag-llm/.env si vous voulez que la porte teste aussi l'appel LLM réel.
HF_API_URL=https://router.huggingface.co/v1/chat/completions
HF_API_TOKEN=
HF_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# ── Sweep multi-modèles CNN (dag_train_model) ────────────────────────────────
MLFLOW_URI=https://gviel-mlflow37.hf.space/
EXPERIMENT_NAME=Vitiscan_CNN_Resnet_INRAE
# Bucket données Vitiscan (dataset + disease.json), distinct du bucket MLflow (aws-s3-mlflow,
# implicite, géré par le SDK MLflow - jamais paramétré par nom ici).
TRAINING_S3_BUCKET=s3-vitiscan-data

# ── AWS S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
