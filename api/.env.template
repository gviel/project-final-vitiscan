# Copier en api/.env (gitignoré) et compléter.
# Fichier réel centralisé dans ~/.vitiscan/api/.env et symlinké ici - cf. link-env.sh à la racine
# pour (re)créer le lien dans un nouveau worktree.

# ── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=https://gviel-mlflow37.hf.space
# id du Logged Model (mlflow>=3.x, format "m-xxxx...") à servir - voir dans l'UI MLflow.
# Valeur ci-dessous vérifiée le 2026-07-09 (cf. docs/refactoring.md) : run "calm-stag-792",
# experiment Vitiscan_CNN_Resnet_INRAE_FINE_TUNING - meilleures métriques (val_acc=0.988,
# test_acc=0.989) parmi tous les runs "Vitiscan_*" audités. extra_files/disease.json renommé sur
# S3 depuis disease-inrae.json pour être compatible avec le chargement de api/app.py.
MLFLOW_MODEL_ID=m-e92c29bf6cf54a6aa096920f480201b9

# ── AWS S3 (lecture des artifacts du modèle par mlflow) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_REGION=eu-west-3

# ── Serveur ───────────────────────────────────────────────────────────────
API_SERVER_PORT=4000
