        <mxCell id="e_t1_neonprodread" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="n_t1" target="n_neon_prod_read">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_t1_stop" value="rien de neuf / erreur S3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;dashed=1;" edge="1" parent="1" source="n_t1" target="n_stop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_t1_t2" value="ajoutés / modifiés / supprimés" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;strokeWidth=2;" edge="1" parent="1" source="n_t1" target="n_t2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_t2_neonval" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="n_t2" target="n_neon_validation">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_t2_t3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;" edge="1" parent="1" source="n_t2" target="n_t3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_t3_svc" value="GET /health, POST /solutions" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="n_t3" target="n_ragllm_val_svc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_svc_hf" value="génération LLM" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="n_ragllm_val_svc" target="n_hf_llm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_svc_neonval" value="recherche vectorielle" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="n_ragllm_val_svc" target="n_neon_validation">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1180" y="600" />
              <mxPoint x="1180" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_t3_t4" value="tous les cas OK" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;strokeWidth=2;" edge="1" parent="1" source="n_t3" target="n_t4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="n_t3_fail" value="≥ 1 échec -&gt; RuntimeError&#10;promotion vers prod annulée&#10;(DAG en échec)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="700" width="90" height="60" as="geometry" />
