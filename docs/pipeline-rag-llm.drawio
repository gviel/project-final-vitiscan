        <!-- ==================== LEGENDE ==================== -->

        <mxCell id="n_legend" value="Légende" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1070" width="200" height="20" as="geometry" />
        </mxCell>

        <mxCell id="n_legend_task" value="Task Airflow (rag_ingestion)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="1100" width="220" height="35" as="geometry" />
        </mxCell>

        <mxCell id="n_legend_gate" value="Porte de qualité (golden prompts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="1100" width="240" height="35" as="geometry" />
