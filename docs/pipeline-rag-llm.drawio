<mxfile host="app.diagrams.net" version="24.7.0" type="device">
  <diagram name="Pipeline RAG-LLM - dag_rag_ingestion" id="vitiscan-dag-rag-ingestion">
    <mxGraphModel dx="1300" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== TITRE / TRIGGER ==================== -->

        <mxCell id="n_title" value="DAG Airflow : dag_rag_ingestion&#10;Ingère les nouveaux documents de connaissance RAG (S3 -&gt; Neon validation -&gt; golden prompts -&gt; Neon prod)" style="text;html=1;align=left;verticalAlign=top;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <mxCell id="n_trigger" value="Déclenchement&#10;cron DAG_RAG_INGESTION_CRON (défaut : 0 * * * *, horaire)" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="360" y="80" width="320" height="50" as="geometry" />
        </mxCell>

        <!-- ==================== TASK 1 : branch_check_new_docs (decision) ==================== -->

        <mxCell id="n_t1" value="Task : branch_check_new_docs&#10;(BranchPythonOperator)&#10;&#10;Liste les .md sous s3://s3-vitiscan-data/knowledge/current/,&#10;calcule un manifest {fichier: hash ETag}, le compare au&#10;manifest déjà enregistré (table rag_knowledge_manifest,&#10;branche Neon prod)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="170" width="380" height="150" as="geometry" />
        </mxCell>

        <mxCell id="n_neon_prod_read" value="Neon (Postgres/pgvector)&#10;branche prod&#10;lit rag_knowledge_manifest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="185" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="n_s3_list" value="AWS S3&#10;s3-vitiscan-data&#10;knowledge/current/*.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="185" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- ==================== BRANCHE : rien de neuf -> stop_dag ==================== -->

        <mxCell id="n_stop" value="Task : stop_dag&#10;(EmptyOperator)&#10;Rien de neuf (ou erreur de listing S3)&#10;- fin du DAG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="370" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- ==================== TASK 2 : download_and_ingest_validation ==================== -->

        <mxCell id="n_t2" value="Task : download_and_ingest_validation&#10;(PythonOperator)&#10;&#10;Ajoutés / modifiés / supprimés détectés.&#10;Télécharge les .md dans work/rag-knowledge/ (vidé avant&#10;chaque run), ingère (chunking + embeddings) dans la&#10;branche Neon de validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="380" width="380" height="140" as="geometry" />
        </mxCell>

        <mxCell id="n_neon_validation" value="Neon (Postgres/pgvector)&#10;branche validation&#10;écrit les chunks + embeddings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="390" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- ==================== TASK 3 : golden_prompts_gate ==================== -->

        <mxCell id="n_t3" value="Task : golden_prompts_gate&#10;(PythonOperator) - PORTE DE QUALITÉ&#10;&#10;Attend /health du service Render vitiscan-rag-llm-validation&#10;(jusqu'à 180s, réveil plan free), puis rejoue chaque cas de&#10;rag-llm/tests/golden_prompts.yaml en HTTP réel (POST /solutions).&#10;Échoue (bloque la suite) si un seul cas échoue." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="580" width="380" height="150" as="geometry" />
        </mxCell>

        <mxCell id="n_ragllm_val_svc" value="Render&#10;vitiscan-rag-llm-validation&#10;(service réellement déployé,&#10;branché sur Neon validation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="565" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="n_hf_llm" value="Hugging Face&#10;Inference Router&#10;Llama-3.1-8B-Instruct" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="660" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="n_gate_note" value="Échec réel (nommage/dosage/diagnostic incorrect) = échec de tâche.&#10;Skip uniquement si le LLM externe est indisponible (hors périmètre&#10;de cette porte, qui teste la résolution du RAG, pas la dispo du LLM)." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="330" y="735" width="380" height="45" as="geometry" />
        </mxCell>

        <!-- ==================== TASK 4 : ingest_prod ==================== -->

        <mxCell id="n_t4" value="Task : ingest_prod&#10;(PythonOperator)&#10;&#10;Golden prompts OK. Réingère les mêmes documents dans la&#10;branche Neon de prod (celle utilisée par rag-llm/ en prod),&#10;puis met à jour rag_knowledge_manifest avec l'état S3&#10;qui vient d'être promu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="810" width="380" height="140" as="geometry" />
        </mxCell>

        <mxCell id="n_neon_prod_write" value="Neon (Postgres/pgvector)&#10;branche prod&#10;écrit les chunks + embeddings&#10;+ met à jour rag_knowledge_manifest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="820" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="n_end" value="Fin du DAG&#10;Les nouveaux documents sont désormais servis en prod&#10;par rag-llm/ (utilisé par ui/) sans interruption de service" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="360" y="980" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- ==================== FLECHES ==================== -->

        <mxCell id="e_trig_t1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="n_trigger" target="n_t1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_t1_s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="n_t1" target="n_s3_list">
