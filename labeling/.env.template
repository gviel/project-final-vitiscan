# Copier en labeling/.env (gitignoré) et compléter.
# Fichier réel centralisé dans ~/.vitiscan/labeling/.env et symlinké ici - cf. link-env.sh à la
# racine pour (re)créer le lien dans un nouveau worktree.

# En local (docker-compose) : http://api:4000 (nom de service)
# En local (hors docker) : http://localhost:4000
API_DIAGNO=http://localhost:4000

# ── AWS S3 (lecture/prévisualisation/déplacement des photos) ────────────────
# Un seul environnement (prod) pour ui/ et labeling/ - pas de variante dev/test séparée.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
PHOTOS_S3_BUCKET=s3-vitiscan-data
# IMPORTANT : même valeur que ui/.env.template (PHOTOS_S3_PREFIX) - sert à localiser puis déplacer
# l'objet S3 d'une photo (incoming/ -> accepted/ ou rejected/) lors d'une décision de tri.
PHOTOS_S3_PREFIX=user-photos/

# Connection string Neon complète (même base prod que ui/ et rag-llm, table différente) - une seule
# variable, pas de PGHOST/PGPORT séparés.
DATABASE_URL=

# Nombre de photos par page dans le dashboard
LABELING_PAGE_SIZE=20
