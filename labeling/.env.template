# Copier en labeling/.env (gitignoré) et compléter.

# En local (docker-compose) : http://api:4000 (nom de service)
# En local (hors docker) : http://localhost:4000
API_DIAGNO=http://localhost:4000

# ── AWS S3 (lecture/prévisualisation des photos) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
PHOTOS_S3_BUCKET=s3-vitiscan-data

# Connection string Neon complète (même base que ui/ et rag-llm en local docker-compose, branche
# Neon "test"/"prod" en déploiement) - une seule variable, pas de PGHOST/PGPORT séparés.
DATABASE_URL=

# Nombre de photos par page dans le dashboard
LABELING_PAGE_SIZE=20
