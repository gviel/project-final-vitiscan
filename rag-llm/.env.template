# Copier en rag-llm/.env (gitignoré) et compléter.

# ── LLM (Hugging Face Inference router, API compatible OpenAI) ──────────────
HF_API_URL=https://router.huggingface.co/v1/chat/completions
HF_API_TOKEN=hf_xxx
HF_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# ── Postgres / pgvector (cf. app/vector_store.py) ────────────────────────────
# 2 modes, dans cet ordre de priorité :
# 1. DATABASE_URL rempli -> Neon (branche test/prod/dev) ou toute URL postgresql://... complète.
# 2. Sinon -> connexion locale (PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE, docker-compose).
DATABASE_URL=
# Utilisés seulement si DATABASE_URL est vide (connexion locale) :
PGHOST=localhost
PGPORT=5433
PGUSER=vitiscan
PGPASSWORD=
PGDATABASE=vitiscan_knowledge

# EN SOMMEIL depuis la migration pgvector — anciennes variables Weaviate via tunnel externe
# (ex: ngrok), conservées commentées pour référence historique, cf. docs/simulation-prod-ngrok.md.
# WEAVIATE_CUSTOM_HTTP_HOST=
# WEAVIATE_CUSTOM_HTTP_PORT=443
# WEAVIATE_CUSTOM_HTTP_SECURE=true
# WEAVIATE_CUSTOM_GRPC_HOST=
# WEAVIATE_CUSTOM_GRPC_PORT=443
# WEAVIATE_CUSTOM_GRPC_SECURE=true

# ── AWS S3 (préparé pour un futur accès direct à s3-vitiscan-data/knowledge/ - non consommé
# aujourd'hui par app/, l'ingestion S3 reste gérée par le DAG Airflow dag_rag_ingestion) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
RAG_S3_BUCKET=s3-vitiscan-data
