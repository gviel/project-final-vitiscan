# Copier en rag-llm/.env (gitignoré) et compléter.

# ── LLM (Hugging Face Inference router, API compatible OpenAI) ──────────────
HF_API_URL=https://router.huggingface.co/v1/chat/completions
HF_API_TOKEN=hf_xxx
HF_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# ── Weaviate ──────────────────────────────────────────────────────────────
# 3 modes (cf. app/weaviate_client.py), dans cet ordre de priorité :
# 1. WEAVIATE_CUSTOM_HTTP_HOST rempli -> Weaviate auto-hébergé exposé via un nom d'hôte externe
#    (ex: tunnel ngrok) - REST et gRPC potentiellement sur des tunnels/ports différents.
# 2. Sinon WEAVIATE_URL rempli -> vrai cluster Weaviate Cloud.
# 3. Sinon -> connexion locale (WEAVIATE_HOST/PORT/GRPC_PORT, docker-compose).
WEAVIATE_API_KEY=
WEAVIATE_URL=
# Utilisés seulement si WEAVIATE_URL est vide (connexion locale) :
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# ── Weaviate via tunnel externe (ex: ngrok) — mode "custom", cf. docs/deploiement-render-streamlit.md
# Laisser vide si non utilisé (mode local ou Cloud ci-dessus prévaut).
WEAVIATE_CUSTOM_HTTP_HOST=
WEAVIATE_CUSTOM_HTTP_PORT=443
WEAVIATE_CUSTOM_HTTP_SECURE=true
WEAVIATE_CUSTOM_GRPC_HOST=
WEAVIATE_CUSTOM_GRPC_PORT=443
WEAVIATE_CUSTOM_GRPC_SECURE=true

# ── AWS S3 (préparé pour un futur accès direct à s3-vitiscan-data/knowledge/ - non consommé
# aujourd'hui par app/, l'ingestion S3 reste gérée par le DAG Airflow dag_rag_ingestion) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
RAG_S3_BUCKET=s3-vitiscan-data
