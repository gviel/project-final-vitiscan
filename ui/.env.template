# Copier en ui/.env (gitignoré) et compléter.

# En local (docker-compose) : http://api:4000 et http://rag-llm:9000 (noms de service)
# En local (hors docker) : http://localhost:4000 et http://localhost:9000
API_DIAGNO=http://localhost:4000
API_SOLUTIONS=http://localhost:9000

# 1 = mode mock (aucun appel API, données factices) - utile pour dev UI sans backend
MOCK=0
DEBUG=0

# ── Sauvegarde photo + métadonnées (S3 + Neon), cf. ui/storage.py et specs.md "Faire évoluer
# pour l'AIA" - alimente labeling/ (labellisation humaine + calcul de drift). Un seul environnement
# (prod) pour ui/ et labeling/ - pas de variante dev/test séparée. ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
PHOTOS_S3_BUCKET=s3-vitiscan-data
PHOTOS_S3_PREFIX=user-photos/
# Connection string Neon complète (une seule variable, pas de PGHOST/PGPORT séparés) - même base
# prod que rag-llm (table différente, vitiscan_photos).
DATABASE_URL=
